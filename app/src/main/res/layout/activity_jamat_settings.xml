<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_gradient_main">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Jamat Times"
        android:textColor="@color/gold_accent"
        android:textSize="32sp"
        android:fontFamily="@font/jameel_noori_nastaleeq"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="32dp"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="4"
        android:shadowRadius="8"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Fajr -->
            <include layout="@layout/item_jamat_setting_row" android:id="@+id/rowFajr"/>
            
            <!-- Dhuhr -->
            <include layout="@layout/item_jamat_setting_row" android:id="@+id/rowDhuhr"/>

            <!-- Asr -->
            <include layout="@layout/item_jamat_setting_row" android:id="@+id/rowAsr"/>

            <!-- Maghrib -->
            <include layout="@layout/item_jamat_setting_row" android:id="@+id/rowMaghrib"/>

            <!-- Isha -->
            <include layout="@layout/item_jamat_setting_row" android:id="@+id/rowIsha"/>

            <!-- Jummah -->
            <include layout="@layout/item_jamat_setting_row" android:id="@+id/rowJummah"/>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap a time to change it."
        android:textColor="@color/text_secondary"
        android:alpha="0.8"
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>
