<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#00000000">

            <!-- Shareable Content Area -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/shareableContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="450dp"
                android:background="#151722"> <!-- Dark Theme base -->

                <!-- Header Decor -->
                <View
                    android:id="@+id/headerDecor"
                    android:layout_width="100dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="24dp"
                    android:background="#D4AF37"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Header Title -->
                <TextView
                    android:id="@+id/tvHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Sun Timings"
                    android:textColor="#D4AF37"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:shadowColor="#000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/headerDecor"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Location -->
                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location..."
                    android:textColor="#E2E8F0"
                    android:textSize="18sp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvHeader"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Current Date -->
                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="18 Feb 2026"
                    android:textColor="#94A3B8"
                    android:fontFamily="@font/jameel_noori_nastaleeq"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tvLocation"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Times Container -->
                <LinearLayout
                    android:id="@+id/layoutTimes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="40dp"
                    app:layout_constraintTop_toBottomOf="@id/tvDate"
                    app:layout_constraintBottom_toTopOf="@id/footer">

                    <!-- Sunrise -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_border_card"
                        android:padding="20dp"
                        android:layout_marginEnd="8dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_sehr"
                            app:tint="#D4AF37"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="طلوع آفتاب"
                            android:textColor="#94A3B8"
                            android:fontFamily="@font/jameel_noori_nastaleeq"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvSunriseTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Sunset -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_border_card"
                        android:padding="20dp"
                        android:layout_marginStart="8dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_iftar"
                            app:tint="#D4AF37"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="غروب آفتاب"
                            android:textColor="#94A3B8"
                            android:fontFamily="@font/jameel_noori_nastaleeq"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvSunsetTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Footer Section (Inside Image) -->
                <LinearLayout
                    android:id="@+id/footer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#1A1C29"
                    android:padding="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textColor="#D4AF37"
                            android:textStyle="bold"
                            android:textSize="18sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download the app to see accurate prayer times anywhere in the world."
                            android:textColor="#94A3B8"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            android:layout_marginEnd="16dp"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivQrCode"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:background="#FFFFFF"
                        android:padding="2dp"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Action Button (Outside Image) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="#0F172A">

                <Button
                    android:id="@+id/btnShare"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Share Image"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:backgroundTint="#D4AF37"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconGravity="textStart"
                    app:iconTint="#0F172A"
                    app:cornerRadius="12dp"/>
            </FrameLayout>

        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>
