<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_qibla"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:keepScreenOn="true"
    >
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/jameel_noori_nastaleeq"
        android:text="Qibla Direction"
        android:textColor="@color/gold_accent"
        android:textSize="32sp" />

    <!-- Compass Container -->
    <RelativeLayout
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_centerInParent="true"
        android:background="@drawable/bg_premium_circle">

        <!-- Compass Dial (Rotating) -->
        <ImageView
            android:id="@+id/ivCompassDial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:src="@drawable/ic_compass_dial" />

        <!-- Qibla Arrow Needle (Pointing and clear) -->
        <ImageView
            android:id="@+id/ivQiblaNeedle"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_qibla_arrow_needle" />

        <!-- Fixed Kaaba Icon at the Top -->
        <ImageView
            android:id="@+id/ivKaabaFixed"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_kaaba_qibla"
            android:elevation="4dp" />

    </RelativeLayout>

    <!-- Info Section -->
    <LinearLayout
        android:id="@+id/infoSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/nav_include"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDegrees"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="0° North"
            android:textColor="@color/text_primary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvQiblaDegrees"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/jameel_noori_nastaleeq"
            android:text="قبلہ کا رخ: --°"
            android:textColor="@color/gold_accent"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:alpha="0.7"
            android:gravity="center"
            android:text="اپنا فون سیدھا رکھیں اور دھاتی اشیاء سے دور رہیں۔"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/jameel_noori_nastaleeq"/>
    </LinearLayout>

    <include
        android:id="@+id/nav_include"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
