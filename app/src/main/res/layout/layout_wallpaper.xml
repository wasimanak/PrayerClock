<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:padding="16dp">

    <!-- Top Section: Date, Location, Clock -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Mon, 01 Jan 2024"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="Location"
            android:textColor="@color/gold_accent"
            android:textSize="14sp"
            android:visibility="gone"
            app:drawableTint="@color/gold_accent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:text="12:00:00"
            android:textColor="@color/text_primary"
            android:textSize="70sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" 
            android:maxLines="1"
            />
            
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Card: Prayer Times -->
    <LinearLayout
        android:id="@+id/cardPrayerTimes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_rounded"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@+id/footerSection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        android:layout_marginBottom="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/jameel_noori_nastaleeq"
                android:gravity="center"
                android:text="اذان"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/jameel_noori_nastaleeq"
                android:gravity="center"
                android:text="جماعت"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/jameel_noori_nastaleeq"
                android:gravity="center"
                android:text="نماز"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/slate_800"
            android:layout_marginBottom="4dp"/>

        <!-- Prayers List (Use weights for equal distribution) -->
        <include
            android:id="@+id/rowFajr"
            layout="@layout/item_prayer_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/rowDhuhr"
            layout="@layout/item_prayer_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/rowAsr"
            layout="@layout/item_prayer_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/rowMaghrib"
            layout="@layout/item_prayer_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
            
        <include
            android:id="@+id/rowIsha"
            layout="@layout/item_prayer_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
            
        <!-- Include Jummah -->
        <include
            android:id="@+id/rowJummah"
            layout="@layout/item_prayer_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
            
        <TextView
            android:id="@+id/lasttime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/jameel_noori_nastaleeq"
            android:gravity="center"
            android:text="Next Prayer..."
            android:textColor="@color/emerald_500"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- Footer Section: Ticker Only -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/marqueeText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:fontFamily="@font/jameel_noori_nastaleeq"
            android:singleLine="true"
            android:text=""
            android:textColor="@color/gold_accent"
            android:textSize="22sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
