<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:clickable="true"
    android:focusable="true">

    <!-- Glowing top background -->
    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-200dp"
        android:alpha="0.3"
        android:background="@drawable/circle_glow" />

    <!-- Top Nav area -->
    <!-- Back button removed per user request -->

    <!-- Sound Toggle -->
    <TextView
        android:id="@+id/btnSoundToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:padding="12dp"
        android:text="🔊"
        android:textSize="24sp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Tasbih Name at top -->
    <TextView
        android:id="@+id/tvTasbihName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:layout_marginHorizontal="24dp"
        android:fontFamily="@font/sakkal"
        android:gravity="center"
        android:text="Tasbih Name"
        android:textColor="@color/gold_accent"
        android:textSize="32sp"
        android:letterSpacing="0.05"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="4"
        android:shadowRadius="8"/>

    <!-- Instruction Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTasbihName"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Tap anywhere to count • Long press to minus"
        android:textColor="#88FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.02"/>

    <!-- Counter Circle Card -->
    <RelativeLayout
        android:id="@+id/counterContainer"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_below="@id/tvTasbihName"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:background="@drawable/bg_premium_circle"
        android:elevation="12dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCounter"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:padding="32dp"
            android:text="0"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-thin"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="30sp"
            app:autoSizeMaxTextSize="110sp"
            app:autoSizeStepGranularity="2sp"
            android:textStyle="normal"
            android:shadowColor="#5000DDFF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="30"/>
            
    </RelativeLayout>

    <!-- AdMob Banner Ad Container (Loaded via Firebase) -->
    <FrameLayout
        android:id="@+id/adContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_above="@id/nav_include"
        android:layout_marginBottom="8dp" />

    <!-- Bottom nav include -->
    <include
        android:id="@+id/nav_include"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />
        
</RelativeLayout>
